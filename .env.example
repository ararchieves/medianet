PUID=1000
PGID=1000
TZ=Asia/Karachi

# App ports
PROWLARR_PORT=9696
SONARR_PORT=8989
RADARR_PORT=7878
BAZARR_PORT=6767
QBITTORRENT_WEBUI_PORT=8080
QBITTORRENT_TORRENT_PORT=6881
FLARESOLVERR_PORT=8191
JELLYFIN_PORT=8096
JELLYSEERR_PORT=5055

# qBittorrent resource tuning
QBITTORRENT_CPU_LIMIT=1.5
QBITTORRENT_MEMORY_LIMIT=1G
QBITTORRENT_CPU_RESERVATION=0.25
QBITTORRENT_MEMORY_RESERVATION=256M
QBITTORRENT_WEBUI_ADDRESS=0.0.0.0
QBITTORRENT_WEBUI_EXTERNAL_ACCESS=true

# FlareSolverr
FLARESOLVERR_LOG_LEVEL=info

# Gluetun VPN
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=openvpn
OPENVPN_USER=your_openvpn_username
OPENVPN_PASSWORD=your_openvpn_password
SERVER_COUNTRIES=Singapore
VPN_PORT_FORWARDING=on
GLUETUN_HEALTHCHECK_URL=http://127.0.0.1:9999/health
